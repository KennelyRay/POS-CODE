{
  "name": "pos-system",
  "version": "1.21.0",
  "private": true,
  "description": "Point of Sale System for KKK-A",
  "author": "KKK-A",
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.11.16",
    "@mui/material": "^5.13.0",
    "@types/exceljs": "^0.5.3",
    "@types/node": "^16.18.0",
    "@types/react": "^18.2.0",
    "@types/react-big-calendar": "^1.16.2",
    "@types/react-dom": "^18.2.0",
    "electron-is-dev": "^2.0.0",
    "escpos": "^3.0.0-alpha.6",
    "escpos-usb": "^3.0.0-alpha.4",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "moment": "^2.30.1",
    "react": "^18.2.0",
    "react-barcode": "^1.4.6",
    "react-big-calendar": "^1.19.2",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.11.0",
    "react-scripts": "4.0.3",
    "react-to-print": "^2.14.13",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "start": "set NODE_OPTIONS=--openssl-legacy-provider && react-scripts start",
    "build": "set NODE_OPTIONS=--openssl-legacy-provider && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "postinstall": "electron-builder install-app-deps",
    "electron": "electron .",
    "build:electron": "npm run build && electron-builder"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "electron": "^28.0.0",
    "electron-builder": "^26.0.12",
    "typescript": "^4.5.5"
  },
  "main": "public/electron.js",
  "build": {
    "appId": "com.kendalstore.pos",
    "productName": "Ken-dal Store POS",
    "files": [
      "build/**/*",
      "public/electron.js",
      "public/preload.js",
      "simple_windows_printer.py",
      "thermal_printer_xp58.py",
      "thermal_printer_basic.py",
      "thermal_printer.py",
      "windows_printer.py",
      "requirements.txt"
    ],
    "extraResources": [
      {
        "from": "assets/icon.png",
        "to": "assets/icon.png"
      },
      {
        "from": "simple_windows_printer.py",
        "to": "simple_windows_printer.py"
      },
      {
        "from": "thermal_printer_xp58.py",
        "to": "thermal_printer_xp58.py"
      },
      {
        "from": "thermal_printer_basic.py",
        "to": "thermal_printer_basic.py"
      },
      {
        "from": "thermal_printer.py",
        "to": "thermal_printer.py"
      },
      {
        "from": "windows_printer.py",
        "to": "windows_printer.py"
      },
      {
        "from": "requirements.txt",
        "to": "requirements.txt"
      },
      {
        "from": "install_python_deps.bat",
        "to": "install_python_deps.bat"
      },
      {
        "from": "xp58_direct_usb.py",
        "to": "xp58_direct_usb.py"
      }
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist-electron-1.21.0-installer"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false,
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  },
  "homepage": "."
}
